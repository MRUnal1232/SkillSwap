# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=skillswap

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
PORT=5000

# ---- Email (optional) ----
# Leave blank in development — the mailer will auto-create an Ethereal test
# account and print preview URLs to the server console instead of actually
# sending mail.
#
# To send real mail (e.g. via Gmail) set all four:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   EMAIL_FROM="SkillSwap <youraddress@gmail.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
